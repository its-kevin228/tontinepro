generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  name      String?
  password  String
  role      Role      @default(MEMBER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  circles   Membership[]
  kyc       KycRequest?
}

model Membership {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  circle    Circle   @relation(fields: [circleId], references: [id])
  circleId  Int
  joinedAt  DateTime @default(now())
}

model Circle {
  id            Int        @id @default(autoincrement())
  name          String
  description   String?
  amount        Float
  frequency     String
  maxMembers    Int
  status        CircleStatus @default(OPEN)
  createdAt     DateTime   @default(now())
  organizerId   Int
  organizer     User       @relation(fields: [organizerId], references: [id])
  invitations   Invitation[]
  cycles        Cycle[]
}

model Invitation {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  circle    Circle   @relation(fields: [circleId], references: [id])
  circleId  Int
  email     String?
  status    String   @default("pending")
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Cycle {
  id         Int       @id @default(autoincrement())
  number     Int
  startDate  DateTime
  endDate    DateTime
  status     String    @default("open")
  circle     Circle    @relation(fields: [circleId], references: [id])
  circleId   Int
  payments   Payment[]
}

model Payment {
  id         Int      @id @default(autoincrement())
  amount     Float
  method     String
  status     String   @default("pending")
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  cycle      Cycle?   @relation(fields: [cycleId], references: [id])
  cycleId    Int?
  createdAt  DateTime @default(now())
}

model KycRequest {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id])
  userId     Int      @unique
  status     String   @default("pending")
  documents  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PlatformSetting {
  id            Int      @id @default(autoincrement())
  serviceFee    Float    @default(1.0)
  transactionFee Float   @default(0.0)
  updatedAt     DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  ORGANISATEUR
  MEMBER
}

enum CircleStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}